# ─────────────────────────────────────────────
#  Mobile App — Environment Variables
#  Copy this to .env.local and fill in your values
# ─────────────────────────────────────────────

# Your development machine's local IP address
# Find it with: ipconfig (Windows) or ifconfig / ip addr (macOS/Linux)
# Must be reachable from both the emulator AND the physical device
# on the same Wi-Fi network.
#
#  Examples:
#    Emulator (Android AVD) → http://10.0.2.2:3000/api/v1
#    Physical device        → http://192.168.1.x:3000/api/v1
#    Expo Go on device      → http://192.168.1.x:3000/api/v1
EXPO_PUBLIC_API_URL=http://192.168.1.x:3000/api/v1
