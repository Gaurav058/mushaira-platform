{
  "cli": {
    "version": ">= 10.0.0"
  },
  "build": {
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "http://192.168.0.113:3000/api/v1"
      }
    },
    "preview-local": {
      "extends": "preview",
      "env": {
        "EXPO_PUBLIC_API_URL": "http://192.168.0.113:3000/api/v1"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
