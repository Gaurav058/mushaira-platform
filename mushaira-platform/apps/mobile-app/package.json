{
  "name": "@mushaira/mobile-app",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "setup-assets": "node setup-assets.js",
    "prebuild": "node setup-assets.js && expo prebuild --platform android --clean",
    "build:apk:local": "node setup-assets.js && expo prebuild --platform android --clean && cd android && gradlew.bat assembleDebug",
    "build:apk:eas": "eas build --platform android --profile preview",
    "build:apk:eas:local-ip": "eas build --platform android --profile preview-local"
  },
  "dependencies": {
    "expo": "~51.0.28",
    "expo-router": "~3.5.23",
    "expo-secure-store": "~13.0.2",
    "expo-font": "~12.0.10",
    "expo-status-bar": "~1.12.1",
    "expo-splash-screen": "~0.27.5",
    "expo-constants": "~16.0.2",
    "expo-linking": "~6.3.1",
    "expo-image": "~1.12.15",
    "expo-file-system": "~17.0.1",
    "@react-native-async-storage/async-storage": "1.23.1",
    "expo-network": "~7.0.4",
    "@expo-google-fonts/inter": "^0.2.3",
    "@expo-google-fonts/playfair-display": "^0.2.3",
    "@expo/vector-icons": "^14.0.2",
    "react": "18.2.0",
    "react-native": "0.74.5",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "3.31.1",
    "react-native-svg": "15.2.0",
    "axios": "^1.6.5"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@types/react": "~18.2.79",
    "typescript": "~5.3.3"
  }
}
